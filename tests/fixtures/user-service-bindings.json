{
  "pinkyPromiseVersion": 1,
  "service": "user-service",
  "bindings": [
    {
      "protocol": "http-json-rest",
      "prefix": "/v1",
      "operations": {
        "getUser": { "method": "GET", "path": "/users/{userId}" },
        "createUser": { "method": "POST", "path": "/users" }
      },
      "connection": { "url": "https://api.example.com" }
    }
  ]
}
